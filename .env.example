# Optional. Without a key, LessonProof runs the same end-to-end workflow with
# a deterministic, schema-compatible fixture so judges can test it safely.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-sol
LESSONPROOF_PLANNER_MODE=fixture
PORT=8787
# Local default is 127.0.0.1. Production defaults to 0.0.0.0 when
# NODE_ENV=production; set HOST explicitly if the platform requires it.
# HOST=0.0.0.0

# Public live-mode safety bounds. Values are per process and intentionally
# conservative; lower them further when the API project has a small budget.
LESSONPROOF_SESSION_TTL_MS=3600000
LESSONPROOF_MAX_SESSIONS=500
LESSONPROOF_ANALYSIS_WINDOW_MS=3600000
LESSONPROOF_ANALYSIS_SESSION_LIMIT=4
LESSONPROOF_ANALYSIS_GLOBAL_LIMIT=50
LESSONPROOF_ANALYSIS_MAX_CONCURRENT=2
