{
  "name": "lessonproof",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Turn expert correction into a verified educational release.",
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "dev": "concurrently -k -n api,web -c yellow,cyan \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "node --watch --import tsx src/server/index.ts",
    "build": "npm run typecheck && vite build",
    "start": "node --import tsx src/server/index.ts",
    "smoke:openai": "node --import tsx scripts/openai-smoke.ts",
    "verify:public": "node --import tsx scripts/release-preflight.ts",
    "verify:submission": "node --import tsx scripts/release-preflight.ts --submission",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run test && npm run build && npm run verify:public"
  },
  "dependencies": {
    "dotenv": "^17.2.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tsx": "^4.20.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.16.5",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^9.2.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.5",
    "vitest": "^3.2.4"
  }
}
